ChocolateToggle.MouseButton1Click:Connect(function()
	autoChocolate = not autoChocolate
	if autoChocolate then
		ChocolateToggle.BackgroundColor3 = Color3.fromRGB(140, 0, 255)
		ChocolateToggle.Text = "Auto Chocolate: ON"
		ChocolateToggle.TextColor3 = Color3.fromRGB(255, 255, 255)
		
		if chocolateRemote then
			chocolateRemote:FireServer()
			lastChocolateTime = os.time()
		end
	else
		ChocolateToggle.BackgroundColor3 = Color3.fromRGB(30, 0, 60)
		ChocolateToggle.Text = "Auto Chocolate: OFF"
		ChocolateToggle.TextColor3 = Color3.fromRGB(200, 200, 200)
	end
end)

task.spawn(function()
	while true do
		if autoLift and muscleRemote then
			muscleRemote:FireServer("Dumbbell Magma")
			muscleRemote:FireServer("Dead Lift Magma")
		end
		task.wait(0.1)
	end
end)

task.spawn(function()
	while true do
		if autoRebirth and rebirthRemote then
			rebirthRemote:FireServer()
		end
		task.wait(0.5)
	end
end)

task.spawn(function()
	while true do
		if autoChocolate and chocolateRemote then
			local currentTime = os.time()
			if (currentTime - lastChocolateTime) >= 240 then
				chocolateRemote:FireServer()
				lastChocolateTime = currentTime
			end
		end
		task.wait(1)
	end
end)
