task.spawn(function()
	while true do
		if autoEquipPets and petRemote then
			local petsFolder = LocalPlayer:FindFirstChild("PetsFolder")
			if petsFolder then
				local count = 0
				for _, pet in ipairs(petsFolder:GetChildren()) do
					if pet.Name == "Divine Horse" then
						petRemote:FireServer("equipPet", pet)
						count = count + 1
						if count >= 4 then
							break
						end
					end
				end
			end
		end
		task.wait(3)
	end
end)

